{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Versioned wire format for sim-flow session events. protocolVersion = 1.",
  "oneOf": [
    {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "definitions": {
          "DiagnosticLevel": {
            "enum": [
              "info",
              "warning",
              "error"
            ],
            "type": "string"
          },
          "GateFailureOut": {
            "properties": {
              "description": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            },
            "required": [
              "description",
              "reason"
            ],
            "type": "object"
          },
          "LlmAttachment": {
            "properties": {
              "data": {
                "description": "Base64-encoded payload bytes. Hosts decode and forward to the LLM. Base64 is used because the protocol is JSONL.",
                "type": "string"
              },
              "mime": {
                "description": "MIME type, e.g. \"image/jpeg\" or \"image/png\".",
                "type": "string"
              },
              "source": {
                "description": "Project-relative source path, surfaced for tracing in logs. Optional because not every attachment originates from a file.",
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "data",
              "mime"
            ],
            "type": "object"
          },
          "LlmMessage": {
            "properties": {
              "attachments": {
                "description": "Optional binary attachments associated with this message. Most messages have none; tool-output user messages may carry image bytes that the agent should treat as inline content (multimodal). The host (extension) is responsible for forwarding these to the underlying LLM via whatever multimodal API the backend supports; if the backend can't accept images the attachments are dropped and a Diagnostic is emitted.",
                "items": {
                  "$ref": "#/definitions/LlmAttachment"
                },
                "type": "array"
              },
              "content": {
                "type": "string"
              },
              "role": {
                "$ref": "#/definitions/LlmRole"
              },
              "tool_call_id": {
                "description": "On `role = Tool` messages: the wire-side call id this message is replying to. Pairs with `LlmToolCall.id` from a prior `LlmEnd` so the model can match tool results to the calls that produced them. `None` on any other role. Backends without a tool-result wire shape (CLI agents, plain chat-completions without tool-use) flatten Tool-role messages into User-role text in their converter.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "tool_calls": {
                "description": "On `role = Assistant` messages: the tool calls this turn emitted (echoed back on subsequent requests so the model sees its own prior calls in history). `None` when the turn produced no native tool calls or when the backend doesn't support them.",
                "items": {
                  "$ref": "#/definitions/LlmToolCall"
                },
                "type": "array"
              }
            },
            "required": [
              "content",
              "role"
            ],
            "type": "object"
          },
          "LlmRole": {
            "oneOf": [
              {
                "enum": [
                  "system",
                  "user",
                  "assistant"
                ],
                "type": "string"
              },
              {
                "description": "Reply to a prior assistant `tool_calls[]` emission. On the OpenAI wire shape, these turns serialize as `{role: \"tool\", tool_call_id: \"<id>\", content: \"...\"}`. CLI agents and non-tool-aware HTTP backends flatten them to User-role text in the converter.",
                "enum": [
                  "tool"
                ],
                "type": "string"
              }
            ]
          },
          "LlmTool": {
            "description": "Tool catalog descriptor for a single advertised tool. Phase 9 M3 fills the `args_schema` with real JSON Schema for arg shapes.",
            "properties": {
              "args_schema": {
                "description": "JSON Schema describing the tool's argument object."
              },
              "description": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "args_schema",
              "description",
              "name"
            ],
            "type": "object"
          },
          "LlmToolCall": {
            "description": "A single tool call the model emitted in a native-tool-use turn. Returned on `HostEvent::LlmEnd.tool_calls`. `arguments_json` is the raw JSON-encoded argument blob the model emitted -- the orchestrator parses it into a `serde_json::Value` at dispatch time so a malformed payload surfaces a clear diagnostic rather than a cryptic serde error mid-pipeline.",
            "properties": {
              "arguments_json": {
                "type": "string"
              },
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "arguments_json",
              "name"
            ],
            "type": "object"
          },
          "SessionEndReason": {
            "description": "Terminal state of a `SessionEnd` event. Closed-set enum so hosts can route on it deterministically (e.g. only re-enable Connect after `Completed`/`Cancelled`/`Error` but treat `RunawayGuard` as a hard abort that requires user attention). Serialized in kebab-case to match the existing wire strings.",
            "oneOf": [
              {
                "description": "Session finished its work cleanly: gate clean, advance happened, or auto-loop walked to the end of the flow.",
                "enum": [
                  "completed"
                ],
                "type": "string"
              },
              {
                "description": "User-initiated cancel via `HostEvent::Cancel` or `/end-session` in TerminalHost.",
                "enum": [
                  "cancelled"
                ],
                "type": "string"
              },
              {
                "description": "Generic error path (LLM dispatch failed, tool error escalated, etc.). The accompanying `message` carries the detail.",
                "enum": [
                  "error"
                ],
                "type": "string"
              },
              {
                "description": "Wire-protocol violation: malformed JSON, unexpected event in the handshake, or anything else that breaks the host / orchestrator contract.",
                "enum": [
                  "protocol-error"
                ],
                "type": "string"
              },
              {
                "description": "Host advertised a `protocolVersion` the orchestrator doesn't speak. Hard fatal.",
                "enum": [
                  "protocol-mismatch"
                ],
                "type": "string"
              },
              {
                "description": "`max_identical_responses` runaway-loop guard tripped. The agent produced N structurally-identical responses in a row; feeding it back another identical prompt is unlikely to help.",
                "enum": [
                  "runaway-guard"
                ],
                "type": "string"
              }
            ]
          },
          "SessionKindOut": {
            "description": "Mirror of `client::SessionKind` exposed in the protocol. Kept independent of the internal type so the wire format stays stable even if the internal representation changes.",
            "enum": [
              "work",
              "critique"
            ],
            "type": "string"
          },
          "SessionTag": {
            "properties": {
              "candidate": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "kind": {
                "$ref": "#/definitions/SessionKindOut"
              },
              "step": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "step"
            ],
            "type": "object"
          },
          "StepDescriptorOut": {
            "description": "Step descriptor sent in `HelloAck`. Same data as `sim-flow describe`'s output, but using protocol-stable field names.",
            "properties": {
              "flow": {
                "type": "string"
              },
              "instruction_path": {
                "type": "string"
              },
              "kind": {
                "$ref": "#/definitions/SessionKindOut"
              },
              "per_candidate": {
                "type": "boolean"
              },
              "phases": {
                "description": "Per-step phases. M2 uses `[\"chat\"]`; M3 expands for code steps to e.g. `[\"author\", \"build\", \"test\", \"coverage\"]`.",
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "predecessor_inputs": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "prerequisite": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "step": {
                "type": "string"
              },
              "tools": {
                "default": [],
                "description": "Tool catalog the orchestrator will advertise to the LLM. Empty in M2; populated by step + kind in M3.",
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "work_artifacts": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "required": [
              "flow",
              "instruction_path",
              "kind",
              "per_candidate",
              "phases",
              "predecessor_inputs",
              "step",
              "work_artifacts"
            ],
            "type": "object"
          },
          "StepMode": {
            "description": "Step-axis mode of the orchestrator. Wire-stable enum serialized as `\"auto\"` / `\"manual\"`. See `docs/brainstorming/manual-step-mode.md`.",
            "oneOf": [
              {
                "description": "Orchestrator walks `current_step` to end of flow without user input.",
                "enum": [
                  "auto"
                ],
                "type": "string"
              },
              {
                "description": "Orchestrator parks after the hello handshake and dispatches sub-sessions only in response to manual-mode host commands.",
                "enum": [
                  "manual"
                ],
                "type": "string"
              }
            ]
          }
        },
        "description": "Event direction: orchestrator -> host.\n\nSerialized as a tagged JSON object with `event` carrying the variant name and the payload fields flattened next to it. We use kebab-case for the tag to match the JSON convention in the extension's existing types.",
        "oneOf": [
          {
            "description": "Reply to the host's `Hello`. Carries the resolved step descriptor so the host knows what kind of session it is hosting and can render header / phase information.",
            "properties": {
              "event": {
                "enum": [
                  "hello-ack"
                ],
                "type": "string"
              },
              "protocol_version": {
                "type": "string"
              },
              "session": {
                "$ref": "#/definitions/SessionTag"
              },
              "sim_flow_version": {
                "type": "string"
              },
              "step_descriptor": {
                "$ref": "#/definitions/StepDescriptorOut"
              }
            },
            "required": [
              "event",
              "protocol_version",
              "session",
              "sim_flow_version",
              "step_descriptor"
            ],
            "type": "object"
          },
          {
            "description": "A chunk of assistant text to render in the chat UI. `final` is true on the last chunk of a single turn.",
            "properties": {
              "event": {
                "enum": [
                  "assistant-text"
                ],
                "type": "string"
              },
              "final_chunk": {
                "type": "boolean"
              },
              "text": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "final_chunk",
              "text"
            ],
            "type": "object"
          },
          {
            "description": "Pause the orchestrator and wait for a `UserMessage` on stdin. Hosts use the optional hints to focus or label the input area.",
            "properties": {
              "event": {
                "enum": [
                  "request-user-input"
                ],
                "type": "string"
              },
              "placeholder": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "prompt": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "event"
            ],
            "type": "object"
          },
          {
            "description": "Ask the host to run an LLM call. Host streams the response back as `LlmChunk` / `LlmEnd` host events tagged with the same `request_id`.",
            "properties": {
              "backend": {
                "type": "string"
              },
              "debug_adaptation": {
                "default": false,
                "type": "boolean"
              },
              "event": {
                "enum": [
                  "request-llm-response"
                ],
                "type": "string"
              },
              "messages": {
                "items": {
                  "$ref": "#/definitions/LlmMessage"
                },
                "type": "array"
              },
              "model": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "model_family_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "request_id": {
                "type": "string"
              },
              "runtime_profile_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "tools": {
                "default": [],
                "description": "Tool catalog for backends that support native tool-use. Empty in M2; populated in M3.",
                "items": {
                  "$ref": "#/definitions/LlmTool"
                },
                "type": "array"
              }
            },
            "required": [
              "backend",
              "event",
              "messages",
              "request_id"
            ],
            "type": "object"
          },
          {
            "description": "The orchestrator wrote a project file. Informational only; the host displays \"wrote spec.md (123 bytes)\" or similar.",
            "properties": {
              "bytes": {
                "format": "uint64",
                "minimum": 0.0,
                "type": "integer"
              },
              "event": {
                "enum": [
                  "artifact-written"
                ],
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "required": [
              "bytes",
              "event",
              "path"
            ],
            "type": "object"
          },
          {
            "description": "The orchestrator executed a tool. Informational; host renders \"reading src/model/lib.rs...\" etc. Phase 9 M3 wires real tool invocations; M2 emits this only for artifact writes.",
            "properties": {
              "args_summary": {
                "type": "string"
              },
              "duration_ms": {
                "format": "uint64",
                "minimum": 0.0,
                "type": "integer"
              },
              "event": {
                "enum": [
                  "tool-invoked"
                ],
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            },
            "required": [
              "args_summary",
              "duration_ms",
              "event",
              "name",
              "status"
            ],
            "type": "object"
          },
          {
            "description": "Session moved to a new phase. Phase 9 M3 introduces the build/test/coverage iteration loop; M2 emits a single `chat` phase for the duration of the session.",
            "properties": {
              "event": {
                "enum": [
                  "phase-changed"
                ],
                "type": "string"
              },
              "phase": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "phase"
            ],
            "type": "object"
          },
          {
            "description": "Output from a build or test runner during a code-step phase. Empty in M2; present in the schema for forward compatibility.",
            "properties": {
              "command": {
                "type": "string"
              },
              "event": {
                "enum": [
                  "build-output"
                ],
                "type": "string"
              },
              "exit_code": {
                "format": "int32",
                "type": "integer"
              },
              "stderr_tail": {
                "type": "string"
              },
              "stdout_tail": {
                "type": "string"
              }
            },
            "required": [
              "command",
              "event",
              "exit_code",
              "stderr_tail",
              "stdout_tail"
            ],
            "type": "object"
          },
          {
            "description": "Result of a gate evaluation. Emitted opportunistically (e.g. after each turn that wrote artifacts) and definitively at session end. Emitting `clean: true` does not by itself advance state - that happens via `StateAdvanced` after successful gate + mark_passed.",
            "properties": {
              "clean": {
                "type": "boolean"
              },
              "event": {
                "enum": [
                  "gate-result"
                ],
                "type": "string"
              },
              "failures": {
                "items": {
                  "$ref": "#/definitions/GateFailureOut"
                },
                "type": "array"
              },
              "step": {
                "type": "string"
              }
            },
            "required": [
              "clean",
              "event",
              "failures",
              "step"
            ],
            "type": "object"
          },
          {
            "description": "The orchestrator advanced `current_step` from one step to another. Emitted right after `mark_passed` + `save`.",
            "properties": {
              "event": {
                "enum": [
                  "state-advanced"
                ],
                "type": "string"
              },
              "from": {
                "type": "string"
              },
              "to": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "event",
              "from"
            ],
            "type": "object"
          },
          {
            "description": "Suggested next action for the host to render as a quick-pick button. Optional capability; hosts that don't advertise `followups` will not receive these.",
            "properties": {
              "action": {
                "type": "string"
              },
              "event": {
                "enum": [
                  "followup"
                ],
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "required": [
              "action",
              "event",
              "label"
            ],
            "type": "object"
          },
          {
            "description": "Non-fatal diagnostic for the host to display.",
            "properties": {
              "event": {
                "enum": [
                  "diagnostic"
                ],
                "type": "string"
              },
              "level": {
                "$ref": "#/definitions/DiagnosticLevel"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "level",
              "message"
            ],
            "type": "object"
          },
          {
            "description": "Session finished. `reason` is the typed terminal state; the optional `message` carries a human-readable detail (often the error string for `error`-class reasons).",
            "properties": {
              "event": {
                "enum": [
                  "session-end"
                ],
                "type": "string"
              },
              "message": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "reason": {
                "$ref": "#/definitions/SessionEndReason"
              }
            },
            "required": [
              "event",
              "reason"
            ],
            "type": "object"
          },
          {
            "description": "The orchestrator's step-axis mode flag changed. Emitted on every flip — by user-issued `SetStepMode`, by the cap-exceeded \"drop to interactive\" path, or by any future internal trigger. The dashboard listens and reflects the current mode in its toggle UI so the visible state always matches the orchestrator's truth.",
            "properties": {
              "event": {
                "enum": [
                  "step-mode-changed"
                ],
                "type": "string"
              },
              "mode": {
                "$ref": "#/definitions/StepMode"
              }
            },
            "required": [
              "event",
              "mode"
            ],
            "type": "object"
          },
          {
            "description": "A sub-session (work or critique) is starting. Emitted by the run loop just before `run_session` begins handling the sub-session. The dashboard uses this to disable per-step buttons while the orchestrator is busy — the pair `SubSessionStarted` / `SubSessionEnded` brackets a contiguous span of LLM streaming + tool calls during which dashboard commands cannot be dispatched.",
            "properties": {
              "event": {
                "enum": [
                  "sub-session-started"
                ],
                "type": "string"
              },
              "kind": {
                "$ref": "#/definitions/SessionKindOut"
              },
              "step": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "kind",
              "step"
            ],
            "type": "object"
          },
          {
            "description": "A sub-session ended. Emitted by the run loop right after `run_session` returns (success, error, or cancellation). The orchestrator typically parks at the next decision point in manual mode, or proceeds to the next sub-session in auto. `outcome` is `\"completed\"`, `\"cancelled\"`, or `\"error\"`.",
            "properties": {
              "event": {
                "enum": [
                  "sub-session-ended"
                ],
                "type": "string"
              },
              "kind": {
                "$ref": "#/definitions/SessionKindOut"
              },
              "outcome": {
                "type": "string"
              },
              "step": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "kind",
              "outcome",
              "step"
            ],
            "type": "object"
          }
        ],
        "title": "Event"
      },
      "title": "Event (orchestrator -> host)"
    },
    {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "definitions": {
          "HostInfo": {
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "version"
            ],
            "type": "object"
          },
          "LlmToolCall": {
            "description": "A single tool call the model emitted in a native-tool-use turn. Returned on `HostEvent::LlmEnd.tool_calls`. `arguments_json` is the raw JSON-encoded argument blob the model emitted -- the orchestrator parses it into a `serde_json::Value` at dispatch time so a malformed payload surfaces a clear diagnostic rather than a cryptic serde error mid-pipeline.",
            "properties": {
              "arguments_json": {
                "type": "string"
              },
              "id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "arguments_json",
              "name"
            ],
            "type": "object"
          },
          "SessionKindOut": {
            "description": "Mirror of `client::SessionKind` exposed in the protocol. Kept independent of the internal type so the wire format stays stable even if the internal representation changes.",
            "enum": [
              "work",
              "critique"
            ],
            "type": "string"
          },
          "StepMode": {
            "description": "Step-axis mode of the orchestrator. Wire-stable enum serialized as `\"auto\"` / `\"manual\"`. See `docs/brainstorming/manual-step-mode.md`.",
            "oneOf": [
              {
                "description": "Orchestrator walks `current_step` to end of flow without user input.",
                "enum": [
                  "auto"
                ],
                "type": "string"
              },
              {
                "description": "Orchestrator parks after the hello handshake and dispatches sub-sessions only in response to manual-mode host commands.",
                "enum": [
                  "manual"
                ],
                "type": "string"
              }
            ]
          }
        },
        "description": "Event direction: host -> orchestrator.",
        "oneOf": [
          {
            "description": "Initial handshake. Host announces its protocol version and optional capabilities.",
            "properties": {
              "capabilities": {
                "default": [],
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "event": {
                "enum": [
                  "hello"
                ],
                "type": "string"
              },
              "host": {
                "$ref": "#/definitions/HostInfo"
              },
              "protocol_version": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "host",
              "protocol_version"
            ],
            "type": "object"
          },
          {
            "description": "User typed (or pasted) the next message in the chat.",
            "properties": {
              "event": {
                "enum": [
                  "user-message"
                ],
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "text"
            ],
            "type": "object"
          },
          {
            "description": "Streaming LLM response chunk fulfilling a prior `RequestLlmResponse`.",
            "properties": {
              "event": {
                "enum": [
                  "llm-chunk"
                ],
                "type": "string"
              },
              "request_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            },
            "required": [
              "event",
              "request_id",
              "text"
            ],
            "type": "object"
          },
          {
            "description": "LLM response finished.",
            "properties": {
              "event": {
                "enum": [
                  "llm-end"
                ],
                "type": "string"
              },
              "request_id": {
                "type": "string"
              },
              "stop_reason": {
                "default": null,
                "type": [
                  "string",
                  "null"
                ]
              },
              "tool_calls": {
                "default": [],
                "description": "Native tool calls the model emitted (when the backend supports native tool-use AND the orchestrator advertised a tool catalog on the matching `RequestLlmResponse`). Empty for fence-mode dispatches and for backends that don't support native tool calls. `#[serde(default)]` keeps the wire shape backward compatible with hosts that haven't been updated.",
                "items": {
